    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst sanitize = (v) => String(v == null ? '' : v).replace(/[\\u0000-\\u001f\\u007f]/g, '').replace(/\\s+/g, ' ').trim().slice(0, 320);\nreturn items.map((item, idx) => {\n  try {\n    const j = item.json || {};\n    const rowRaw = j.row_number ?? j.source_row_number ?? '';\n    const rowNumber = Number(rowRaw);\n    const idRaw = String(j.ID ?? '').trim();\n\n    if ((!Number.isFinite(rowNumber) || rowNumber < 1) && !idRaw) return null;\n\n    const email1Col = ('E-mail' in j) ? 'E-mail' : ('E-mail 1' in j ? 'E-mail 1' : ('Email' in j ? 'Email' : 'E-mail'));\n    const email2Col = ('E-mail 2' in j) ? 'E-mail 2' : ('Email 2' in j ? 'Email 2' : 'E-mail 2');\n    const email3Col = (' E-mail 3' in j) ? ' E-mail 3' : (('E-mail 3' in j) ? 'E-mail 3' : (('Email 3' in j) ? 'Email 3' : 'E-mail 3'));\n\n    const out = {};\n    if (idRaw) out.ID = idRaw;\n    if (Number.isFinite(rowNumber) && rowNumber >= 1) out.row_number = rowNumber;\n\n    out[email1Col] = sanitize(j.email_1);\n    out[email2Col] = sanitize(j.email_2);\n    out[email3Col] = sanitize(j.email_3);\n\n    return { json: out, pairedItem: item.pairedItem ?? { item: idx } };\n  } catch (err) {\n    return null;\n  }\n}).filter(Boolean);"
      },
